# ─────────────────────────────────────────────────────────────────────────────
# JORINOVA NEXUS — Settings template
# Copy to `.env` and fill in real values. Defaults shown are dev-safe.
# Loaded by `backend/core/config.py` via pydantic-settings.
# ─────────────────────────────────────────────────────────────────────────────

# App
DEBUG=false
SECRET_KEY=change-this-to-a-32-char-random-string-before-prod
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (sqlite for dev, postgresql for prod)
DB_ENGINE=sqlite
DB_NAME=alis_x.db
# For postgres:
# DB_ENGINE=postgresql
# DB_USER=nexus
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# JWT auth
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE=480

# ── AI — Local LLM (Ollama hybrid worker pool) ──────────────────────────────
# Each role can target a different Ollama model. The router picks per task.
# Tip on small hardware: keep num_ctx ≤ 2048 (already enforced in code) so
# even phi3:mini fits in <3 GiB RAM. Larger models (mistral, llama3) need
# ~5 GiB free.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_MODEL_FAST=phi3:mini
OLLAMA_MODEL_DEEP=mistral
OLLAMA_MODEL_CHAT=nous-hermes
OLLAMA_MODEL_GENERAL=llama3
OLLAMA_MODEL_FALLBACK=tinyllama
LOCAL_AI_TIMEOUT=15

# ── AI — Cloud LLM (Anthropic Claude) ────────────────────────────────────────
# Required if you want the cascade to fall back to cloud when local LLM is
# unavailable / too slow. Get a key at https://console.anthropic.com.
# The cascade in training_intent.py: regex → local LLM → cloud → unknown.
# Without this key, the cloud stage is skipped silently.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLOUD_AI_TIMEOUT=30

# AI cache
AI_CACHE_SIZE=512

# Static / Media
STATIC_URL=/static
MEDIA_URL=/media
