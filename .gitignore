# ════════════════════════════════════════════════
#  JORINOVA NEXUS — .gitignore
# ════════════════════════════════════════════════

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.pyo
*.pyw
.Python
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/
.env.local
.env.*.local

# Environment & secrets
.env
.env.production
.env.staging
# Example templates are tracked — they contain no secrets
!.env.example
!.env.*.example
*.secret
secrets.json
local_settings.py

# Django
*.sqlite3
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
static_root/
*.log
local.py

# Celery
celerybeat-schedule
celerybeat-schedule.db
celerybeat.pid

# Redis
dump.rdb
redis-server.pid

# Coverage & testing
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.pytest_cache/
.cache/
nosetests.xml
coverage.xml
*.cover

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST
wheels/
.eggs/

# Node (if any tooling is ever added)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE / editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V7
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Migrations (keep in version control — comment out to ignore)
# */migrations/

# Backup files
*.bak
*.orig
*.rej

# Jupyter
.ipynb_checkpoints/
*.ipynb
# Source notebooks intended for distribution (Colab, training material)
# remain tracked despite the blanket *.ipynb rule above.
!notebooks/*.ipynb

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Profiling
*.prof

# Docker
docker-compose.override.yml

# ═══ CRITICAL SECURITY — NEVER COMMIT ════════════════════════════
backend/.env.production    # Production secrets
backend/.env.staging       # Staging secrets
backend/.env               # Any env with real secrets
nginx/certs/               # SSL private keys
scripts/backup_*.sql.gz    # Database backups
backups/                   # Local backup directory
media/                     # Uploaded patient files / staff photos

# Database files (SQLite dev only — PostgreSQL for production)
backend/alis_x.db
backend/alis_x.db-shm
backend/alis_x.db-wal

# Generated secrets
secrets_generated_*.txt

# Logs
logs/
*.log

# AI model cache (very large)
.ollama/
models/

# Generated training data and benchmark outputs (regenerated by scripts).
# Hand-curated golden sets in /golden_set and backend/training/golden ARE tracked.
/datasets/
backend/training/datasets/
backend/training/benchmark.json
