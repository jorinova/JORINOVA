# ─────────────────────────────────────────────────────────────────────────────
# JORINOVA NEXUS — Frontend production env
# Copy to `.env.production` for local production-style runs; in Docker,
# pass these as build-args or compose `environment:` entries.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL the BROWSER uses to reach the API.
# - Behind nginx (recommended): leave empty so the client uses relative
#   /api/* — nginx proxies it to the backend container.
# - Direct (no nginx): set to your backend origin, e.g.
#       NEXT_PUBLIC_API_URL=https://api.nexus.hospital.rw
NEXT_PUBLIC_API_URL=

# Base URL the SERVER side uses to reach the API (only matters for SSR
# rewrites). Inside docker-compose this is the backend service name.
BACKEND_INTERNAL_URL=http://api:8000

# Disable Next.js telemetry phone-home.
NEXT_TELEMETRY_DISABLED=1
